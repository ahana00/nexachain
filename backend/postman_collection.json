{
  "info": { "name": "Nexachain API", "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json" },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    { "name": "Register", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}],
      "url": "{{baseUrl}}/auth/register",
      "body": { "mode": "raw", "raw": "{\"fullName\":\"John Doe\",\"email\":\"john@example.com\",\"mobile\":\"9999999999\",\"password\":\"pass1234\"}" }}},
    { "name": "Login", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}],
      "url": "{{baseUrl}}/auth/login",
      "body": { "mode": "raw", "raw": "{\"email\":\"john@example.com\",\"password\":\"pass1234\"}" }}},
    { "name": "Create Investment", "request": { "method": "POST",
      "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{token}}"}],
      "url": "{{baseUrl}}/investments",
      "body": { "mode": "raw", "raw": "{\"amount\":1000,\"planName\":\"Starter\",\"durationDays\":30,\"dailyRoiPercent\":1.5}" }}},
    { "name": "List Investments", "request": { "method": "GET",
      "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": "{{baseUrl}}/investments" }},
    { "name": "Dashboard", "request": { "method": "GET",
      "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": "{{baseUrl}}/dashboard" }},
    { "name": "Direct Referrals", "request": { "method": "GET",
      "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": "{{baseUrl}}/referrals/direct" }},
    { "name": "Referral Tree", "request": { "method": "GET",
      "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": "{{baseUrl}}/referrals/tree" }}
  ]
}
